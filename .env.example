# Copy to .env.local for local dev. On Vercel, set these in Project Settings → Environment Variables.

# Supabase — from Supabase project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# QR token signing — any long random string (openssl rand -hex 32)
QR_TOKEN_SECRET=change_me_to_a_long_random_hex_string

# Cron endpoint auth — different random string
CRON_SECRET=change_me_to_a_different_long_random_hex_string

# Kitchen contact (WhatsApp digest link)
NEXT_PUBLIC_KITCHEN_WHATSAPP=+590XXXXXXXXX

# Public base URL (used to build absolute links in emails and QRs)
NEXT_PUBLIC_APP_URL=https://menu.piratebynight.com
